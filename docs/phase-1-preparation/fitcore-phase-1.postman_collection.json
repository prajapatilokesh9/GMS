{
  "info": {
    "_postman_id": "fitcore-phase1-api",
    "name": "FitCore Pro Phase 1 API",
    "description": "API collection for FitCore Pro Phase 1 - Core fitness SaaS platform",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
