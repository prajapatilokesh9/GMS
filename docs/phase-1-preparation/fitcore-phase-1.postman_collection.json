            "body": {
              "mode": "raw",
              "raw": "{
  \"status\": \"approved\"
}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{gymId}/documents/{docId}/status",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{gymId}", "documents", "{docId}", "status"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/gyms/{gymId}/documents/{docId}",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{gymId}", "documents", "{docId}"]
            }
          },
          "response": []
        }
      ]
    },
