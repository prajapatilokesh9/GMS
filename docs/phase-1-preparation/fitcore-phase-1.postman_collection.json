            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Gym Management",
      "description": "Gym CRUD and management endpoints",
      "item": [
        {
          "name": "Create Gym",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{
  \"gymName\": \"Demo Active Gym\",
  \"email\": \"gym@example.com\",
  \"phone\": \"+1234567890\",
  \"addressLine1\": \"123 Fitness Street\",
  \"city\": \"Mumbai\",
  \"state\": \"Maharashtra\",
  \"country\": \"IN\",
  \"pincode\": \"400001\",
  \"licenseNumber\": \"LIC-2024-001\",
  \"maxStaffCount\": 10,
  \"maxMemberCount\": 500,
  \"openingTime\": \"06:00\",
  \"closingTime\": \"22:00\",
  \"operatingDays\": \"Mon,Tue,Wed,Thu,Fri,Sat,Sun\"
}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms",
              "host": ["{{baseUrl}}"],
              "path": ["gyms"]
            }
          },
          "response": []
        },
        {
          "name": "List Gyms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/gyms?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["gyms"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Gym by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/gyms/{id}",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{id}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Gym",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{
  \"gymName\": \"Updated Gym Name\",
  \"city\": \"Updated City\"
}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{id}",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{id}"]
            }
          },
          "response": []
        },
        {
          "name": "Verify Gym",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{
  \"onboardingStatus\": \"active\"
}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{id}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{id}", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "Reject Gym",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{
  \"onboardingStatus\": \"rejected\",
  \"rejectionReason\": \"Business license did not match registered address.\"
}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{id}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{id}", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "Get My Gyms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/gyms/my",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "my"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Document Management",
      "description": "Gym document upload and management endpoints",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "value": "", "type": "file" },
                { "key": "documentType", "value": "business_license" },
                { "key": "uploadedBy", "value": "{userId}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{gymId}/documents",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{gymId}", "documents"]
            }
          },
          "response": []
        },
        {
          "name": "List Documents",
          "request": {
